  "parameters": {
    "IdPath": { "name": "id", "in": "path", "type": "string", "required": true, "description": "资源ID" },
    "RequiredCategoryIdQuery": { "name": "category_id", "in": "query", "type": "string", "required": true, "description": "分类ID" },
    "OptionalCategoryIdQuery": { "name": "category_id", "in": "query", "type": "string", "required": false, "description": "分类ID" },
    "PageNumQuery": { "name": "page_num", "in": "query", "type": "integer", "required": false, "default": 1, "minimum": 1, "maximum": 100, "description": "页码" },
    "PageSizeQuery": { "name": "page_size", "in": "query", "type": "integer", "required": false, "default": 10, "minimum": 1, "maximum": 100, "description": "每页数量" },
    "NormalDisabledStatusQuery": { "name": "status", "in": "query", "type": "integer", "required": false, "enum": [0, 1], "description": "状态。多数内容接口：1正常，0禁用；不传为全部" },
    "UserStatusQuery": { "name": "status", "in": "query", "type": "integer", "required": false, "enum": [0, 1], "description": "用户状态；不传为全部" },
    "CourseStatusQuery": { "name": "status", "in": "query", "type": "integer", "required": false, "enum": [0, 1], "description": "课程状态：0正常，1禁用；不传为全部" },
    "CourseTypeQuery": { "name": "course_type", "in": "query", "type": "integer", "required": false, "enum": [0, 1], "description": "课程类型：0普通课程，1视频课程" },
    "SortByQuery": { "name": "sort_by", "in": "query", "type": "string", "required": false, "enum": ["publish", "view", "favourite"], "default": "publish", "description": "排序方式" }
  },
  "responses": {
    "EmptySuccessResponse": {
