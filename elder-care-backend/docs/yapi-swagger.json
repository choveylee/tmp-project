{
  "swagger": "2.0",
  "info": {
    "title": "elder-care-backend API",
    "description": "YApi import document generated from Go router, handler and data structs. Public APIs use /api/v1/public. Admin APIs use /api/v1/admin and require Authorization: Bearer <access_token> unless noted.",
    "version": "1.0.0"
  },
  "basePath": "/",
  "schemes": ["http", "https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Bearer <access_token>"
    }
  },
  "tags": [
    { "name": "Health", "description": "健康检查" },
    { "name": "Public Common", "description": "公开端通用接口" },
    { "name": "Public Banner", "description": "公开端轮播图接口" },
    { "name": "Public Article", "description": "公开端文章接口" },
    { "name": "Public Course", "description": "公开端课程接口" },
    { "name": "Admin Session", "description": "管理端登录接口" },
    { "name": "Admin Common", "description": "管理端通用接口" },
    { "name": "Admin User", "description": "管理端用户接口" },
    { "name": "Admin Banner", "description": "管理端轮播图接口" },
    { "name": "Admin Article", "description": "管理端文章接口" },
